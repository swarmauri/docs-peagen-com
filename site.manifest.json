{
  "host": "docs.peagen.com",
  "zone": "peagen.com",
  "repository": "swarmauri/docs-peagen-com",
  "siteKind": "zdx-docs",
  "orchestrator": "npmctl",
  "dnsProvider": "namecheap",
  "deployment": "self-hosted-docker",
  "dockerService": "docs-peagen-com",
  "records": [
    {
      "type": "CNAME",
      "host": "docs",
      "value": "docs.peagen.com",
      "ttl": 300
    }
  ],
  "proxyManager": {
    "provider": "nginx-proxy-manager",
    "apiEndpoint": "https://nginx.bz23.xyz/"
  }
}
