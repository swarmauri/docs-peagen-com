{
  "name": "docs-peagen-com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "uv run zdx serve --generate --docs-dir . --manifest api_manifest.yaml --on-error warn",
    "build": "uv run zdx generate --docs-dir . --manifest api_manifest.yaml --on-error warn && uv run mkdocs build -f mkdocs.yml",
    "check": "uv run zdx generate --docs-dir . --manifest api_manifest.yaml --on-error warn && uv run mkdocs build -f mkdocs.yml",
    "docker:build": "docker compose build docs-peagen-com",
    "dns:plan": "npmctl plan desired-state/dns.yaml --owner docs-peagen-com",
    "dns:apply": "npmctl apply desired-state/dns.yaml --owner docs-peagen-com",
    "deploy:dry-run": "node scripts/deploy.mjs --dry-run",
    "deploy": "docker compose -f docker-compose.yaml up -d --build --force-recreate --no-deps docs-peagen-com",
    "dns:doctor": "npmctl dns doctor --provider namecheap",
    "proxy:validate": "npmctl validate desired-state/proxy.yaml",
    "proxy:plan": "npmctl plan desired-state/proxy.yaml --owner docs-peagen-com",
    "proxy:apply": "npmctl apply desired-state/proxy.yaml --owner docs-peagen-com",
    "proxy:target-check": "node scripts/validate-proxy-target.mjs"
  }
}
